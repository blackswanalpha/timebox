{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeBox",
  "version": "0.1.0",
  "identifier": "com.mbugua.timebox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "title": "TimeBox",
        "width": 400,
        "height": 450,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "alwaysOnTop": true
      },
      {
        "label": "main",
        "title": "TimeBox",
        "width": 690,
        "height": 944,
        "center": true,
        "resizable": false,
        "visible": false,
        "closable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: 'unsafe-inline'; img-src 'self' tauri: asset: data:; media-src 'self' tauri: asset: data:; connect-src 'self' https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWQ4+wQph1dDqoz+eVelV8g8bKGQp4xnpk51mOjIt0fFO/RahIECwLRD",
      "endpoints": [
        "https://github.com/blackswanalpha/timebox/releases/latest/download/latest.json"
      ]
    }
  }
}